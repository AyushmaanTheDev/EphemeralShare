# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string in production
MONGO_URI=mongodb://localhost:27017/ephemeralshare

# ─── File Storage ──────────────────────────────────────────
# Absolute or relative path to local upload directory
UPLOAD_DIR=uploads

# ─── Expiry ────────────────────────────────────────────────
# Time-to-live for each shared file, in milliseconds
# Default: 86400000 = 24 hours
FILE_TTL_MS=86400000

# ─── CORS ──────────────────────────────────────────────────
# Frontend origin — restrict this in production
FRONTEND_URL=http://localhost:5173
